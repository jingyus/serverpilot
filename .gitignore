# ============================================================================
# ServerPilot Community Edition .gitignore
# ============================================================================
# 这是用于开源仓库的 .gitignore 示例
# 在发布开源版本时，将此文件复制为 .gitignore

# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
*.tsbuildinfo

# Logs
*.log
logs/
test.log
dev.log
autorun.log
npm-debug.log*
pnpm-debug.log*

# Environment variables (重要：不要上传敏感配置)
.env
.env.local
.env.*.local
.env.production

# Database
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
data/

# IDE and editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/
*.tmp

# Test and coverage
coverage/
.nyc_output/

# State files (生成的状态文件不提交)
AUTORUN_STATE.md
CURRENT_TASK.md
STATE.md

# History
.history/

# Test artifacts
test-results/
playwright-report/

# Fly.io
.fly/

# ============================================================================
# ⚠️ Cloud Edition (Enterprise Features) - NOT INCLUDED IN OPEN SOURCE
# ============================================================================
# 以下文件/目录仅在商业版（Cloud Edition）中提供，不包含在开源版本中

# Cloud package (PostgreSQL, Billing, SAML SSO, Skills, etc.)
packages/cloud/

# Cloud-specific configuration files
docker-compose.cloud.yml
scripts/start-cloud-dev.sh
scripts/autorun_cloud.sh

# Cloud-specific logs and state
cloud_test.log
autorun_cloud.log

# Cloud type definitions (if server doesn't need them)
packages/server/src/types/cloud.d.ts

# ============================================================================
# ⚠️ Internal Development Documentation - NOT INCLUDED IN OPEN SOURCE
# ============================================================================

# Automation state files (generated by internal automation scripts)
AUTORUN_*.md
CURRENT_*.md
*_TASK_QUEUE.md
STATE.md
CLOUD_AUTO_DEV.md
EDITION_MATRIX.md
.claude.md

# Internal Chinese documentation
使用说明.md*
开源发布-简易版.md

# Temporary opensource release files (remove after release)
OPENSOURCE_RELEASE_CHECKLIST.md
QUICKSTART_OPENSOURCE.md
DOCS_CLASSIFICATION.md
SCRIPTS_CLASSIFICATION.md
DIRECTORIES_CLASSIFICATION.md
DOCS_SUMMARY.md
OPENSOURCE_FINAL_SUMMARY.md
OPENSOURCE_SIMPLE_GUIDE.md
.gitignore.opensource-example

# Internal documentation (docs/)
docs/TODO.md
docs/云*.md
docs/*项目分析.md
docs/开发*.md
docs/autorun-*.md
docs/token-usage-notes.md
docs/需求文档.md
docs/版本*.md
docs/产品*.md
docs/技术方案.md
docs/改进方案-*.md
docs/命令审批*.md
docs/文件上传*.md
docs/multi-tenant-design.md
docs/task-queue-*.md
docs/git-integration-guide.md
docs/gitee-setup.md
docs/ai-tools-enhanced.md
docs/authentication-architecture.md
docs/使用说明.md
docs/握手.md
docs/项目清单.md
docs/AI开发约束.md
docs/DevOps产品方案.md
docs/SERVERPILOT技术方案.md
docs/OPENSOURCE_STRATEGY.md
docs/SECURITY.md
docs/md文档/

# Internal backup files
*.bak

# ============================================================================
# Internal Scripts - NOT INCLUDED IN OPEN SOURCE
# ============================================================================
# Use whitelist mode: exclude all scripts except those needed for users/contributors

# Exclude all scripts
scripts/*

# Whitelist: scripts needed in open source
!scripts/install.sh
!scripts/dev-setup.sh

# ============================================================================
# Temporary & Generated Directories - NOT INCLUDED IN OPEN SOURCE
# ============================================================================

# Editor history
.history/

# Test artifacts and reports
playwright-report/
test-results/

# ============================================================================
# Tests - Exclude EE/Cloud/Internal Tests
# ============================================================================

# EE/Cloud version tests
tests/docker-compose-ee.test.ts
tests/e2e-ce-to-ee-upgrade.test.ts
tests/e2e-ce-edition.test.ts
tests/quota-enforcement-acceptance.test.ts

# Internal/Debug tests
tests/debug-chat-error.test.ts
tests/licensing-compliance.test.ts
tests/database-deployment.test.ts
tests/deployment-verification.test.ts
tests/smoke/

# Test backup files
tests/*.bak
