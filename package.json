{
  "name": "aiinstaller",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered intelligent remote installation platform",
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:server": "pnpm --filter @aiinstaller/server dev",
    "dev:agent": "pnpm --filter @aiinstaller/agent dev",
    "dev:dashboard": "pnpm --filter @aiinstaller/dashboard dev",
    "build": "pnpm -r build",
    "build:server": "pnpm --filter @aiinstaller/server build",
    "build:agent": "pnpm --filter @aiinstaller/agent build",
    "build:dashboard": "pnpm --filter @aiinstaller/dashboard build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint packages/*/src/**/*.ts",
    "lint:fix": "eslint packages/*/src/**/*.ts --fix",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf packages/*/dist packages/*/node_modules/.cache",
    "build:binary": "bun scripts/build-binary.ts",
    "build:binary:all": "bun scripts/build-binary.ts --all"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.13.1",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.1",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.54.0",
    "vitest": "^3.0.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^3.25.76"
  }
}
