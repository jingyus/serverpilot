{
  "name": "aiinstaller",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0",
  "description": "AI-powered intelligent remote installation platform",
  "repository": {
    "type": "git",
    "url": "https://github.com/serverpilot/serverpilot.git"
  },
  "homepage": "https://github.com/serverpilot/serverpilot#readme",
  "bugs": {
    "url": "https://github.com/serverpilot/serverpilot/issues"
  },
  "author": "ServerPilot Contributors",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @aiinstaller/shared build && pnpm -r --parallel dev",
    "dev:server": "pnpm --filter @aiinstaller/server dev",
    "dev:agent": "pnpm --filter @aiinstaller/agent dev",
    "dev:dashboard": "pnpm --filter @aiinstaller/dashboard dev",
    "dev:agent-daemon": "pnpm --filter @aiinstaller/agent build && node packages/agent/dist/index.js --daemon --server ws://localhost:3000",
    "build": "pnpm -r build",
    "build:server": "pnpm --filter @aiinstaller/server build",
    "build:agent": "pnpm --filter @aiinstaller/agent build",
    "build:dashboard": "pnpm --filter @aiinstaller/dashboard build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --no-warn-ignored packages/*/src/**/*.ts",
    "lint:fix": "eslint --no-warn-ignored packages/*/src/**/*.ts --fix",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "typecheck": "tsc --noEmit && pnpm --filter @aiinstaller/dashboard typecheck",
    "clean": "rm -rf packages/*/dist packages/*/node_modules/.cache",
    "build:binary": "bun scripts/build-binary.ts",
    "build:binary:all": "bun scripts/build-binary.ts --all",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "release": "tsx scripts/release.ts",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.13.1",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^3.0.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.3",
    "zod": "^3.25.76"
  },
  "lint-staged": {
    "packages/{server,agent,shared}/**/*.ts": [
      "eslint --no-warn-ignored --fix",
      "prettier --write"
    ],
    "packages/dashboard/**/*.{ts,tsx}": [
      "prettier --write"
    ]
  }
}
