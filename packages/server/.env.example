# ==============================================================================
# ServerPilot Environment Variables / 环境变量配置模板
# ==============================================================================
# This is the Self-Hosted configuration (100% open source, all features enabled).
# 这是自部署版本配置 (100% 开源，所有功能完整可用)。
#
# ServerPilot is zero-config by design — works out of the box!
# ServerPilot 采用零配置设计，开箱即用！
#
# You can run `docker compose up -d` directly without configuring this file.
# 可直接运行 `docker compose up -d` 启动，无需配置此文件。
# All variables below are optional — only set them when customization is needed.
# 以下变量均为可选配置，仅在需要自定义时使用。
# ==============================================================================
# Deployment Modes / 部署模式:
#   Self-Hosted (default) — 100% open source, deploy on your own servers
#   自部署版本 (默认) — 100% 开源，部署在自己的服务器上
#     - All core features enabled (multi-server, team collaboration, webhooks, etc.)
#     - 所有核心功能完整可用 (多服务器、团队协作、Webhook 等)
#     - Bring your own AI API Key
#     - 需要自己申请 AI API Key
#     - You manage infrastructure (backups, updates, security)
#     - 自己管理基础设施 (备份、更新、安全)
#
#   Cloud (serverpilot.io) — Official managed SaaS service
#   云版本 (serverpilot.io) — 官方托管 SaaS 服务
#     - Same features + official AI Key + auto-backup + enterprise SSO
#     - 相同功能 + 官方 AI Key + 自动备份 + 企业 SSO
#     - No infrastructure management needed
#     - 无需管理基础设施
#     - Starting from $19/month
#     - 价格从 $19/月起
# ==============================================================================
# Custom setup / 自定义配置:
#   ./init.sh              # Guided setup + start / 引导式配置 + 启动 (推荐)
#   # Or manually / 或手动配置:
#   cp .env.example .env   # Copy template / 复制模板
#   # Edit .env as needed / 编辑 .env 文件修改所需变量
#   docker compose up -d   # Start services / 启动服务
# ==============================================================================

# ------------------------------------------------------------------------------
# Docker Compose Configuration / Docker Compose 配置
# ------------------------------------------------------------------------------

# Dashboard external port (access via http://localhost:3001)
# Dashboard 外部访问端口 (浏览器访问 http://localhost:3001)
# Default / 默认: 3001
DASHBOARD_PORT=3001

# ------------------------------------------------------------------------------
# Security / 安全配置
# ------------------------------------------------------------------------------

# JWT secret (at least 32 characters, used for auth token signing)
# JWT 密钥 (至少 32 字符, 用于用户认证签名)
# Default / 默认: auto-generated / 自动生成
# IMPORTANT: Change this in production!
# 生产环境请务必修改!
# Generate / 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=change_me_to_a_random_string_at_least_32_chars

# ------------------------------------------------------------------------------
# Server Configuration / 服务端配置
# ------------------------------------------------------------------------------

# Deployment mode / 部署模式: Self-Hosted (false) or Cloud (true)
# Cloud mode enables infrastructure enhancements (SAML SSO, compliance, managed backups).
# Cloud 模式启用基础设施增强功能 (SAML SSO、合规报告、托管备份)。
# All core features (multi-server, team, webhooks) are enabled in both modes.
# 所有核心功能 (多服务器、团队、Webhook) 在两种模式下都完整可用。
# Default / 默认: false (Self-Hosted / 自部署版本)
CLOUD_MODE=false

# Runtime environment / 运行环境: development | production | test
# Default / 默认: production
NODE_ENV=production

# Server listen port / 服务端监听端口
# Default / 默认: 3000
SERVER_PORT=3000

# Listen address / 监听地址
# Default / 默认: 0.0.0.0
SERVER_HOST=0.0.0.0

# CORS allowed origin(s) / CORS 允许的来源域名
# Controls which domains can make cross-origin requests to the API.
# 控制哪些域名可以向 API 发起跨域请求。
# Default / 默认: * (allow all origins / 允许所有域名)
# WARNING: In production, set this to your actual domain for security!
# 警告: 生产环境中请设置为实际域名以提高安全性!
# Single origin / 单个域名:   CORS_ORIGIN=https://your-dashboard.example.com
# Multiple origins / 多个域名: CORS_ORIGIN=https://app.example.com,https://admin.example.com
CORS_ORIGIN=*

# ------------------------------------------------------------------------------
# AI Configuration (optional — AI features require an API Key)
# AI 配置 (可选 - AI 功能需要 API Key)
# ------------------------------------------------------------------------------

# AI Provider: claude | openai | deepseek | ollama | custom-openai
# AI Provider 选择: claude | openai | deepseek | ollama | custom-openai
# Default / 默认: claude
# Options / 说明:
#   claude       — Anthropic Claude (Tier 1, recommended / 推荐)
#   openai       — OpenAI official API / 官方 API (Tier 2)
#   deepseek     — DeepSeek official API / 官方 API (Tier 2)
#   ollama       — Local Ollama instance / 本地 Ollama 实例 (Tier 3, no API Key needed / 无需 API Key)
#   custom-openai — Any OpenAI-compatible API / 任何 OpenAI 兼容 API (Tier 2, OneAPI/LiteLLM/Azure)
AI_PROVIDER=claude

# AI model name (universal for all providers)
# AI 模型名称 (所有 Provider 通用)
# Recommended models per provider / 不同 Provider 的推荐模型:
#   claude:        claude-sonnet-4-5（推荐别名）或 claude-sonnet-4-5-20250929
#   openai:        gpt-4o
#   deepseek:      deepseek-chat
#   ollama:        llama3
#   custom-openai: depends on backend / 取决于后端配置
# Default / 默认: claude-sonnet-4-5
AI_MODEL=claude-sonnet-4-5

# AI request timeout in milliseconds / AI 请求超时 (毫秒)
# Default / 默认: 30000 (custom-openai: 60000)
AI_TIMEOUT_MS=30000

# AI max retries / AI 最大重试次数
# Default / 默认: 3
AI_MAX_RETRIES=3

# --- Claude (AI_PROVIDER=claude) ---

# Anthropic Claude API Key
# Default / 默认: empty (AI features unavailable, but system still works)
# 默认: 空 (AI 功能不可用，但系统仍可正常运行)
# Get your key / 获取方式: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- OpenAI (AI_PROVIDER=openai) ---

# OpenAI API Key (only needed when AI_PROVIDER=openai)
# OpenAI API Key (仅 AI_PROVIDER=openai 时需要)
# Get your key / 获取方式: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- DeepSeek (AI_PROVIDER=deepseek) ---

# DeepSeek API Key (only needed when AI_PROVIDER=deepseek)
# DeepSeek API Key (仅 AI_PROVIDER=deepseek 时需要)
# Get your key / 获取方式: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# --- Custom OpenAI Compatible API (AI_PROVIDER=custom-openai) ---
# --- 自定义 OpenAI 兼容 API (AI_PROVIDER=custom-openai) ---
# Works with any service providing /v1/chat/completions endpoint:
# 适用于任何兼容 OpenAI /v1/chat/completions 接口的服务:
#   - OneAPI:  Multi-model gateway / 多模型聚合网关
#   - LiteLLM: Unified LLM proxy / 统一 LLM 代理
#   - Azure OpenAI: Microsoft-hosted OpenAI / 微软 Azure 托管的 OpenAI
#   - vLLM / FastChat / LocalAI: Self-hosted inference / 自建推理服务

# Custom OpenAI API Base URL (required when using custom-openai)
# Custom OpenAI API Base URL (使用 custom-openai 时必填)
# Must include /v1 path prefix / 必须包含 /v1 路径前缀
# Examples / 示例:
#   OneAPI:    https://your-oneapi.example.com/v1
#   LiteLLM:  http://localhost:4000/v1
#   Azure:    https://your-resource.openai.azure.com/v1
#   vLLM:     http://localhost:8000/v1
CUSTOM_OPENAI_BASE_URL=

# Custom OpenAI API Key (required when using custom-openai)
# Custom OpenAI API Key (使用 custom-openai 时必填)
# Provided by your API gateway or inference service
# 由你的 API 网关或推理服务提供
CUSTOM_OPENAI_API_KEY=

# ------------------------------------------------------------------------------
# GitHub OAuth (optional — enables GitHub one-click login)
# GitHub OAuth 配置 (可选 - 启用 GitHub 一键登录)
# ------------------------------------------------------------------------------

# GitHub OAuth App Client ID
# Create at / 创建方式: https://github.com/settings/applications/new
# Default / 默认: empty (GitHub login disabled / GitHub 登录不可用)
GITHUB_OAUTH_CLIENT_ID=

# GitHub OAuth App Client Secret
# Default / 默认: empty / 空
GITHUB_OAUTH_CLIENT_SECRET=

# GitHub OAuth callback URL / GitHub OAuth 回调地址
# Default / 默认: http://localhost:3000/api/v1/auth/github/callback
# Change to your actual domain in production
# 生产环境需要修改为实际域名
GITHUB_OAUTH_REDIRECT_URI=

# ------------------------------------------------------------------------------
# WebSocket Configuration / WebSocket 配置
# ------------------------------------------------------------------------------

# WebSocket heartbeat interval in milliseconds / WebSocket 心跳间隔 (毫秒)
# Default / 默认: 30000
WS_HEARTBEAT_INTERVAL_MS=30000

# WebSocket connection timeout in milliseconds / WebSocket 连接超时 (毫秒)
# Default / 默认: 10000
WS_CONNECTION_TIMEOUT_MS=10000

# Whether WebSocket requires authentication / WebSocket 是否需要认证 (true | false)
# Default / 默认: true
WS_REQUIRE_AUTH=true

# ------------------------------------------------------------------------------
# Knowledge Base / 知识库配置
# ------------------------------------------------------------------------------

# Knowledge base directory path (Docker internal: /app/knowledge-base)
# 知识库目录路径 (Docker 内部路径: /app/knowledge-base)
# Default / 默认: ./knowledge-base
KNOWLEDGE_BASE_DIR=./knowledge-base

# GitHub API token (for automatic doc fetching)
# GitHub API Token (用于文档自动抓取)
# Default / 默认: empty (rate-limited without token / 不使用 token 有速率限制)
# Get your token / 获取方式: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Doc fetching check interval in hours / 文档自动抓取检查间隔 (小时)
# Default / 默认: 24
KB_CHECK_INTERVAL_HOURS=24

# Run doc fetching on startup / 启动时是否立即运行文档抓取 (true | false)
# Default / 默认: true
KB_RUN_ON_START=true

# Max concurrent fetches / 最大并发抓取数
# Default / 默认: 3
KB_MAX_CONCURRENT=3

# ------------------------------------------------------------------------------
# Logging / 日志配置
# ------------------------------------------------------------------------------

# Log level / 日志级别: debug | info | warn | error
# Default / 默认: info
LOG_LEVEL=info

# Log file path (leave empty in Docker — outputs to console only)
# 日志文件路径 (Docker 环境留空，仅输出到控制台)
# Default / 默认: empty / 空
LOG_FILE=

# ------------------------------------------------------------------------------
# Database (SQLite — zero config) / 数据库配置 (SQLite - 零配置)
# ------------------------------------------------------------------------------

# Database file path (Docker internal: /data/serverpilot.db)
# 数据库文件路径 (Docker 内部路径: /data/serverpilot.db)
# Default / 默认: /data/serverpilot.db
# Note: Data persisted in Docker volume 'server-data'
# 注意: 数据持久化在 Docker volume 'server-data' 中
DATABASE_PATH=/data/serverpilot.db

# ------------------------------------------------------------------------------
# Agent Configuration / 客户端配置 (packages/agent)
# ------------------------------------------------------------------------------

# Server WebSocket URL / 服务端 WebSocket 地址
# Default / 默认: ws://localhost:3000
INSTALL_SERVER_URL=ws://localhost:3000

# Command execution timeout in milliseconds / 命令执行超时 (毫秒)
# Default / 默认: 120000
COMMAND_TIMEOUT_MS=120000

# Enable dry-run mode / 是否启用 dry-run 模式 (true | false)
# Default / 默认: false
DRY_RUN=false

# ------------------------------------------------------------------------------
# Default Admin Account (used only on first startup)
# 默认管理员账户 (仅首次启动时使用)
# ------------------------------------------------------------------------------

# Admin email / 管理员邮箱
# Default / 默认: admin@serverpilot.local
ADMIN_EMAIL=admin@serverpilot.local

# Admin password (minimum 8 characters)
# 管理员密码 (最少 8 字符)
# Default / 默认: empty (auto-generated, shown in server logs)
# 默认: 空 (自动生成随机密码，显示在服务器日志中)
ADMIN_PASSWORD=

# ------------------------------------------------------------------------------
# Local Server Auto-Registration / 本地服务器自动注册
# ------------------------------------------------------------------------------

# Skip automatic local server creation on startup
# 跳过启动时自动创建本地服务器
# Set to 'true' for cloud/multi-server deployments
# 云端/多服务器部署时设为 'true'
# Default / 默认: false (auto-creates local server for self-hosted mode)
# SKIP_SEED_LOCAL_SERVER=true
