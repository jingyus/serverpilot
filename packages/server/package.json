{
  "name": "@aiinstaller/server",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0",
  "description": "AI Installer server - WebSocket server with AI agent integration",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schema": {
      "import": "./dist/db/schema.js",
      "types": "./dist/db/schema.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "dev:compile": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aiinstaller/shared": "workspace:*",
    "@anthropic-ai/sdk": "^0.91.1",
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@hono/node-server": "^1.19.9",
    "better-sqlite3": "^12.9.0",
    "cron-parser": "^5.5.0",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "jose": "^6.2.3",
    "js-yaml": "^4.1.1",
    "nodemailer": "^8.0.7",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "ws": "^8.20.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.0",
    "@types/ws": "^8.18.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
