# ==============================================================================
# ServerPilot Enterprise Edition (EE) — Environment Variables
# ServerPilot 企业版 (EE) — 环境变量配置
# ==============================================================================
# Quick start / 快速开始:
#   cp .env.ee.example .env      # Copy this template / 复制此模板
#   # Fill in required values     / 填写必填项
#   pnpm start                   # Start server / 启动服务
# ==============================================================================

# ------------------------------------------------------------------------------
# Edition / 版本标识 (DO NOT CHANGE / 请勿修改)
# ------------------------------------------------------------------------------

# Edition type: ee = Enterprise Edition (multi-server, team collaboration)
# 版本类型: ee = 企业版 (多服务器、团队协作)
EDITION=ee

# Cloud mode enabled for SaaS deployment (enables multi-tenant + billing)
# 云端模式 (启用多租户隔离 + 订阅计费)
# Set to false for self-hosted EE / 自托管 EE 设为 false
CLOUD_MODE=true

# ------------------------------------------------------------------------------
# Server Configuration / 服务端配置
# ------------------------------------------------------------------------------

# Runtime environment / 运行环境: development | production
# Default / 默认: production
NODE_ENV=production

# Server listen port / 服务端监听端口
# Default / 默认: 3000
SERVER_PORT=3000

# Listen address / 监听地址
# Default / 默认: 0.0.0.0
SERVER_HOST=0.0.0.0

# CORS allowed origin(s) / CORS 允许的来源域名
# In production, set to your actual domain / 生产环境请设置为实际域名
# Example / 示例: https://app.serverpilot.io
CORS_ORIGIN=https://app.serverpilot.io

# ------------------------------------------------------------------------------
# Security / 安全配置
# ------------------------------------------------------------------------------

# JWT secret (at least 32 characters, used for auth token signing)
# JWT 密钥 (至少 32 字符, 用于认证签名)
# IMPORTANT: Must change in production! / 生产环境请务必修改!
# Generate / 生成: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=

# ------------------------------------------------------------------------------
# Database (PostgreSQL — recommended for EE)
# 数据库 (PostgreSQL — EE 推荐)
# ------------------------------------------------------------------------------

# Database type / 数据库类型: sqlite | postgres
# EE recommends PostgreSQL for high availability / EE 推荐 PostgreSQL 以保证高可用
DB_TYPE=postgres

# PostgreSQL connection URL (required when DB_TYPE=postgres)
# PostgreSQL 连接地址 (DB_TYPE=postgres 时必填)
# Format / 格式: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://serverpilot:password@localhost:5432/serverpilot

# SQLite fallback path (only used when DB_TYPE=sqlite)
# SQLite 备用路径 (仅 DB_TYPE=sqlite 时使用)
# DATABASE_PATH=./data/serverpilot.db

# ------------------------------------------------------------------------------
# AI Configuration (required for AI features)
# AI 配置 (AI 功能必需)
# ------------------------------------------------------------------------------

# AI Provider: claude | openai | deepseek | ollama | custom-openai
# Default / 默认: claude (recommended / 推荐)
AI_PROVIDER=claude

# AI model name / AI 模型名称
# Recommended per provider / 推荐模型:
#   claude:        claude-sonnet-4-20250514
#   openai:        gpt-4o
#   deepseek:      deepseek-chat
#   ollama:        llama3
#   custom-openai: depends on backend / 取决于后端
# Default / 默认: claude-sonnet-4-20250514
AI_MODEL=claude-sonnet-4-20250514

# --- Claude (AI_PROVIDER=claude) ---

# Anthropic API Key (required for claude provider)
# Get your key / 获取: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- OpenAI (AI_PROVIDER=openai) ---

# OpenAI API Key (only when AI_PROVIDER=openai)
# Get your key / 获取: https://platform.openai.com/api-keys
# OPENAI_API_KEY=
# OPENAI_BASE_URL=

# --- DeepSeek (AI_PROVIDER=deepseek) ---

# DeepSeek API Key (only when AI_PROVIDER=deepseek)
# Get your key / 获取: https://platform.deepseek.com/
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=

# --- Custom OpenAI Compatible (AI_PROVIDER=custom-openai) ---
# Works with OneAPI, LiteLLM, Azure OpenAI, vLLM, etc.
# CUSTOM_OPENAI_BASE_URL=
# CUSTOM_OPENAI_API_KEY=

# --- Ollama (AI_PROVIDER=ollama) ---
# No API key needed / 无需 API Key
# Requires local Ollama running / 需要本地运行 Ollama
# OLLAMA_BASE_URL=http://localhost:11434

# AI request timeout in ms / AI 请求超时 (毫秒)
# Default / 默认: 30000
# AI_TIMEOUT_MS=30000

# AI max retries / AI 最大重试次数
# Default / 默认: 3
# AI_MAX_RETRIES=3

# ------------------------------------------------------------------------------
# GitHub OAuth (EE feature) / GitHub OAuth 登录 (EE 功能)
# ------------------------------------------------------------------------------

# GitHub OAuth App credentials / GitHub OAuth 应用凭据
# Create at / 创建: https://github.com/settings/applications/new
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# OAuth callback URL / OAuth 回调地址
# Must match GitHub OAuth App settings / 必须与 GitHub 应用设置一致
GITHUB_OAUTH_REDIRECT_URI=https://app.serverpilot.io/api/v1/auth/github/callback

# ------------------------------------------------------------------------------
# API Rate Limiting (EE feature) / API 速率限制 (EE 功能)
# ------------------------------------------------------------------------------

# Disable rate limiting (for development only)
# 关闭速率限制 (仅用于开发)
# RATE_LIMIT_DISABLED=false

# ------------------------------------------------------------------------------
# SMTP / Email Notifications (for alerts)
# SMTP / 邮件通知 (用于告警)
# ------------------------------------------------------------------------------

# SMTP server configuration / SMTP 服务器配置
# Required for email alert notifications / 启用邮件告警通知需要配置
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=alerts@serverpilot.dev
# SMTP_FROM_NAME=ServerPilot Alerts

# ------------------------------------------------------------------------------
# Knowledge Base / 知识库 (optional / 可选)
# ------------------------------------------------------------------------------

# Knowledge base directory / 知识库目录
# Default / 默认: ./knowledge-base
KNOWLEDGE_BASE_DIR=./knowledge-base

# GitHub token for doc fetching (optional, higher rate limit)
# GitHub Token 用于文档抓取 (可选, 提高速率限制)
# Get your token / 获取: https://github.com/settings/tokens
# GITHUB_TOKEN=

# Knowledge base check interval in hours / 知识库检查间隔 (小时)
# Default / 默认: 24
# KB_CHECK_INTERVAL_HOURS=24

# Run knowledge base fetch on server startup / 启动时执行知识库抓取
# Default / 默认: true
# KB_RUN_ON_START=true

# Max concurrent knowledge base fetch operations / 最大并发抓取数
# Default / 默认: 3
# KB_MAX_CONCURRENT=3

# ------------------------------------------------------------------------------
# WebSocket Configuration / WebSocket 配置 (optional / 可选)
# ------------------------------------------------------------------------------

# WebSocket heartbeat interval in ms / WebSocket 心跳间隔 (毫秒)
# Default / 默认: 30000
# WS_HEARTBEAT_INTERVAL_MS=30000

# WebSocket connection timeout in ms / WebSocket 连接超时 (毫秒)
# Default / 默认: 10000
# WS_CONNECTION_TIMEOUT_MS=10000

# Require WebSocket authentication / 要求 WebSocket 认证
# Default / 默认: true
# WS_REQUIRE_AUTH=true

# WebSocket auth timeout in ms / WebSocket 认证超时 (毫秒)
# Default / 默认: 10000
# WS_AUTH_TIMEOUT_MS=10000

# ------------------------------------------------------------------------------
# Session Management / 会话管理 (optional / 可选)
# ------------------------------------------------------------------------------

# Session retention period in days / 会话保留天数
# Expired sessions are cleaned up automatically / 过期会话自动清理
# SESSION_RETENTION_DAYS=30

# ------------------------------------------------------------------------------
# Agent Binary Distribution / Agent 二进制分发 (optional / 可选)
# ------------------------------------------------------------------------------

# Base URL for agent binary downloads / Agent 二进制下载地址
# Default / 默认: https://releases.serverpilot.ai/agent
# AGENT_BINARY_BASE_URL=https://releases.serverpilot.ai/agent

# ------------------------------------------------------------------------------
# Default Admin Account (first startup only)
# 默认管理员账户 (仅首次启动)
# ------------------------------------------------------------------------------

# Admin email / 管理员邮箱
ADMIN_EMAIL=admin@serverpilot.io

# Admin password (min 8 characters)
# 管理员密码 (最少 8 字符)
# Default / 默认: auto-generated, shown in server logs / 自动生成, 显示在日志中
# ADMIN_PASSWORD=

# Skip admin seed / 跳过管理员创建
# SKIP_SEED_ADMIN=false

# Skip local server seed / 跳过本地服务器创建
# SKIP_SEED_LOCAL_SERVER=false

# ------------------------------------------------------------------------------
# Logging / 日志 (optional / 可选)
# ------------------------------------------------------------------------------

# Log level / 日志级别: debug | info | warn | error
# Default / 默认: info
# LOG_LEVEL=info

# Log file path (empty = console only)
# 日志文件路径 (留空 = 仅控制台输出)
# LOG_FILE=

# ==============================================================================
# EE Edition Notes / EE 版本说明
# ==============================================================================
# Enterprise Edition includes ALL Community Edition features PLUS:
# 企业版包含所有社区版功能，另外还有:
#
#   - Multi-server management    (add/remove/group servers)
#   - Team collaboration         (RBAC: Owner/Admin/Member)
#   - Team invitation system     (email-based invitations)
#   - Webhook notifications      (5 event types, HMAC signing)
#   - Alert rules & triggers     (CPU/memory/disk thresholds)
#   - Real-time metrics          (SSE push, CPU/memory/disk)
#   - Audit log export           (CSV/JSON)
#   - GitHub OAuth login         (third-party authentication)
#   - API rate limiting          (sliding window, per-user/IP)
#
# Cloud-only features (CLOUD_MODE=true):
# 云端专属功能 (CLOUD_MODE=true):
#
#   - Multi-tenant isolation     (row-level data separation)
#   - Subscription billing       (Stripe integration)
#
# To downgrade to Community Edition:
# 降级到社区版:
#   Set EDITION=ce in your .env file / 在 .env 中设置 EDITION=ce
#   See .env.ce.example / 参见 .env.ce.example
# ==============================================================================
