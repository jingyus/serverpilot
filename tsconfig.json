{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@aiinstaller/shared": ["packages/shared/src"],
      "@aiinstaller/server": ["packages/server/src"],
      "@aiinstaller/agent": ["packages/agent/src"],
      "@aiinstaller/dashboard": ["packages/dashboard/src"]
    }
  },
  "include": ["packages/*/src/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "packages/dashboard/**"]
}
