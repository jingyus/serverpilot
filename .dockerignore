# Dependencies
node_modules
packages/*/node_modules

# Build output (rebuilt inside Docker)
dist
packages/*/dist

# Development files
*.test.ts
*.test.tsx
**/*.test.ts
**/*.test.tsx
tests/
coverage/
.nyc_output/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

