# Dependencies
node_modules
packages/*/node_modules

# Build output (rebuilt inside Docker)
dist
packages/*/dist

# Development files
*.test.ts
*.test.tsx
**/*.test.ts
**/*.test.tsx
tests/
coverage/
.nyc_output/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Git
.git
.gitignore

# Environment (secrets should not be in the image)
.env
.env.local
.env.*.local

# Documentation (not needed in image, except knowledge-base)
docs/
*.md
!knowledge-base/**/*.md

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Misc
.github/
openclaw-modules/
PROMPT.md
TODO.md
STATE.md

# Note: agent package is built inside Docker, so we need its source code
# Tests and tsconfig are already excluded by the general rules above
