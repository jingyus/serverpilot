.env
.env.local
.env.*.local

# Documentation (not needed in image, except knowledge-base)
docs/
*.md
!knowledge-base/**/*.md

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Misc
.github/
openclaw-modules/
PROMPT.md
TODO.md
STATE.md

# Packages not needed for Docker build (keep package.json for pnpm workspace resolution)
packages/agent/src/
packages/agent/dist/
packages/agent/tests/
packages/agent/tsconfig.json
