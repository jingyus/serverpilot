---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'ServerPilot — AI 驱动的 DevOps 平台' } = Astro.props;
const pageTitle = `${title} - ServerPilot`;
const ogImage = new URL('/og-image.png', Astro.site ?? 'https://serverpilot.ai').href;
const GITHUB_REPO = 'https://github.com/jingjinbao/ServerPilot';

const pathname = Astro.url.pathname;
// Normalize: treat "/foo/" and "/foo" the same; root "/" stays "/"
const normalizedPath = pathname === '/' ? '/' : pathname.replace(/\/$/, '');

function isActive(href: string): boolean {
  const normalizedHref = href === '/' ? '/' : href.replace(/\/$/, '');
  if (normalizedHref === '/') return normalizedPath === '/';
  return normalizedPath === normalizedHref || normalizedPath.startsWith(normalizedHref + '/');
}

const navLinks = [
  { href: '/', label: '首页' },
  { href: '/docs', label: '文档' },
  { href: '/download', label: '下载' },
  { href: '/pricing', label: '定价' },
] as const;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={Astro.url.href} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={Astro.url.href} />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <header class="border-b sticky top-0 bg-white/80 backdrop-blur-sm z-50">
      <nav class="container mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-2xl font-bold text-primary-600">ServerPilot</a>
        <div class="hidden md:flex gap-8">
          {navLinks.map(({ href, label }) => (
            <a
              href={href}
              class:list={[
                'transition-colors',
                isActive(href) ? 'text-primary-600 font-semibold' : 'hover:text-primary-600',
              ]}
              {...(isActive(href) ? { 'aria-current': 'page' as const } : {})}
            >{label}</a>
          ))}
          <a href={GITHUB_REPO} target="_blank" class="hover:text-primary-600 transition-colors">GitHub</a>
        </div>
        <a href="/download" class="hidden md:inline-flex btn-primary">开始使用</a>
        <!-- Mobile hamburger button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 -mr-2 text-gray-700 hover:text-primary-600 transition-colors"
          aria-label="打开导航菜单"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </nav>
      <!-- Mobile menu panel -->
      <div id="mobile-menu" class="mobile-menu-closed md:hidden border-t bg-white">
        <div class="container mx-auto px-6 py-4 flex flex-col gap-4">
          {navLinks.map(({ href, label }) => (
            <a
              href={href}
              class:list={[
                'py-2 transition-colors',
                isActive(href) ? 'text-primary-600 font-semibold' : 'hover:text-primary-600',
              ]}
              {...(isActive(href) ? { 'aria-current': 'page' as const } : {})}
            >{label}</a>
          ))}
          <a href={GITHUB_REPO} target="_blank" class="py-2 hover:text-primary-600 transition-colors">GitHub</a>
          <a href="/download" class="btn-primary text-center mt-2">开始使用</a>
        </div>
      </div>
    </header>
    <script>
      const btn = document.getElementById('mobile-menu-btn')!;
      const menu = document.getElementById('mobile-menu')!;
      const icon = document.getElementById('menu-icon')!;

      function closeMenu() {
        menu.classList.remove('mobile-menu-open');
        menu.classList.add('mobile-menu-closed');
        btn.setAttribute('aria-expanded', 'false');
        btn.setAttribute('aria-label', '打开导航菜单');
        icon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
      }

      btn.addEventListener('click', () => {
        const isOpen = menu.classList.toggle('mobile-menu-open');
        menu.classList.toggle('mobile-menu-closed', !isOpen);
        btn.setAttribute('aria-expanded', String(isOpen));
        btn.setAttribute('aria-label', isOpen ? '关闭导航菜单' : '打开导航菜单');
        icon.setAttribute('d', isOpen ? 'M6 18L18 6M6 6l12 12' : 'M4 6h16M4 12h16M4 18h16');
      });

      // ESC key closes menu
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && menu.classList.contains('mobile-menu-open')) {
          closeMenu();
        }
      });

      // Clicking nav links inside menu closes it
      menu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => closeMenu());
      });
    </script>

    <main>
      <slot />
    </main>

    <footer class="border-t mt-20 py-12 bg-gray-50">
      <div class="container mx-auto px-6">
        <div class="grid md:grid-cols-4 gap-8">
          <div>
            <h3 class="font-bold text-lg mb-4">ServerPilot</h3>
            <p class="text-gray-600 text-sm">AI 驱动的 DevOps 平台</p>
          </div>
          <div>
            <h4 class="font-semibold mb-4">产品</h4>
            <ul class="space-y-2 text-sm text-gray-600">
              <li><a href="/docs" class="hover:text-primary-600">文档</a></li>
              <li><a href="/download" class="hover:text-primary-600">下载</a></li>
              <li><a href="/pricing" class="hover:text-primary-600">定价</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold mb-4">社区</h4>
            <ul class="space-y-2 text-sm text-gray-600">
              <li><a href={GITHUB_REPO} target="_blank" class="hover:text-primary-600">GitHub</a></li>
              <li><a href={`${GITHUB_REPO}/discussions`} target="_blank" class="hover:text-primary-600">讨论区</a></li>
              <li><a href={`${GITHUB_REPO}/issues`} target="_blank" class="hover:text-primary-600">问题反馈</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold mb-4">关于</h4>
            <ul class="space-y-2 text-sm text-gray-600">
              <li><a href={`${GITHUB_REPO}/blob/master/LICENSE`} target="_blank" class="hover:text-primary-600">许可证</a></li>
              <li><a href={`${GITHUB_REPO}/releases`} target="_blank" class="hover:text-primary-600">更新日志</a></li>
              <li><a href={`${GITHUB_REPO}/blob/master/CONTRIBUTING.md`} target="_blank" class="hover:text-primary-600">贡献指南</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-8 pt-8 border-t text-center text-sm text-gray-500">
          © {new Date().getFullYear()} ServerPilot · Licensed under <a href={`${GITHUB_REPO}/blob/master/LICENSE`} target="_blank" class="hover:text-primary-600 underline">AGPL-3.0</a>
        </div>
      </div>
    </footer>
  </body>
</html>
