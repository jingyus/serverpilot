---
import BaseLayout from '../layouts/BaseLayout.astro';
import CheckIcon from '../components/CheckIcon.astro';
import CodeBlock from '../components/CodeBlock.astro';
---

<BaseLayout title="下载" description="下载 ServerPilot 开源版或注册云服务版">
  <!-- BreadcrumbList 结构化数据 -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "首页", "item": "https://serverpilot.ai/" },
      { "@type": "ListItem", "position": 2, "name": "下载" }
    ]
  })} />

  <section class="container mx-auto px-6 py-20">
    <div class="max-w-4xl mx-auto">
      <!-- 面包屑导航 -->
      <nav class="text-sm text-gray-500 mb-8">
        <a href="/" class="hover:text-primary-600">首页</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">下载</span>
      </nav>

      <h1 class="text-4xl font-bold mb-6 text-center">下载 ServerPilot</h1>
      <p class="text-gray-600 text-center mb-12">选择适合你的版本开始使用</p>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- 开源版 -->
        <div class="border-2 border-primary-500 rounded-lg p-8 hover:shadow-lg transition-shadow relative">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-primary-600 text-white px-4 py-1 rounded-full text-sm">
            推荐
          </div>
          <div class="mb-6">
            <h2 class="text-2xl font-bold mb-2">开源版</h2>
            <p class="text-gray-600">完全免费，自行部署</p>
          </div>

          <div class="mb-6">
            <div class="text-3xl font-bold mb-4">免费</div>
            <ul class="space-y-3 text-sm text-gray-600">
              <li class="flex items-start">
                <CheckIcon />
                <span>完整的核心功能</span>
              </li>
              <li class="flex items-start">
                <CheckIcon />
                <span>无服务器数量限制</span>
              </li>
              <li class="flex items-start">
                <CheckIcon />
                <span>社区支持</span>
              </li>
              <li class="flex items-start">
                <CheckIcon />
                <span>AGPL-3.0 开源协议</span>
              </li>
            </ul>
          </div>

          <div class="space-y-3">
            <a href="https://github.com/jingjinbao/ServerPilot/releases/latest" target="_blank" class="block w-full text-center btn-primary">
              下载最新版本
            </a>
            <a href="https://github.com/jingjinbao/ServerPilot" target="_blank" class="block w-full text-center btn-secondary">
              查看源代码
            </a>
          </div>
        </div>

        <!-- 云服务版 -->
        <div class="border rounded-lg p-8 hover:shadow-lg transition-shadow">
          <div class="mb-6">
            <h2 class="text-2xl font-bold mb-2">云服务版</h2>
            <p class="text-gray-600">托管服务，开箱即用</p>
          </div>

          <div class="mb-6">
            <div class="text-3xl font-bold text-gray-400 mb-4">敬请期待</div>
            <ul class="space-y-3 text-sm text-gray-600">
              <li class="flex items-start">
                <CheckIcon />
                <span>开源版所有功能</span>
              </li>
              <li class="flex items-start">
                <CheckIcon />
                <span>托管服务，无需自行部署</span>
              </li>
              <li class="flex items-start">
                <CheckIcon />
                <span>企业级技术支持</span>
              </li>
              <li class="flex items-start">
                <CheckIcon />
                <span>自动备份与高可用</span>
              </li>
              <li class="flex items-start">
                <CheckIcon />
                <span>团队协作与权限管理</span>
              </li>
            </ul>
          </div>

          <div class="space-y-3">
            <span class="block w-full text-center btn-primary opacity-50 cursor-not-allowed">
              即将推出
            </span>
            <a href="/pricing" class="block w-full text-center btn-secondary">
              查看详细定价
            </a>
          </div>
        </div>
      </div>

      <!-- 安装说明 -->
      <div class="mt-16 bg-gray-50 rounded-lg p-8">
        <h2 class="text-2xl font-bold mb-2">快速安装</h2>
        <p class="text-sm text-gray-500 mb-6">适用于<strong>生产部署</strong>场景 — 通过 Docker 一键启动，无需安装 Node.js 环境。</p>

        <div class="space-y-6">
          <div>
            <h3 class="font-semibold mb-3 flex items-center">
              <span class="bg-primary-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-sm mr-3">1</span>
              克隆仓库
            </h3>
            <CodeBlock class="ml-9" code="git clone https://github.com/jingjinbao/ServerPilot.git\ncd ServerPilot">
              git clone https://github.com/jingjinbao/ServerPilot.git<br/>
              cd ServerPilot
            </CodeBlock>
          </div>

          <div>
            <h3 class="font-semibold mb-3 flex items-center">
              <span class="bg-primary-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-sm mr-3">2</span>
              一键启动
            </h3>
            <CodeBlock class="ml-9" code="# 引导式配置并启动（推荐）\n./init.sh\n\n# 或零配置直接启动（开箱即用）\ndocker compose up -d">
              <span class="text-gray-500"># 引导式配置并启动（推荐）</span><br/>
              ./init.sh<br/>
              <br/>
              <span class="text-gray-500"># 或零配置直接启动（开箱即用）</span><br/>
              docker compose up -d
            </CodeBlock>
            <p class="ml-9 mt-2 text-sm text-gray-500">零配置即可运行。如需使用 AI 功能，在 .env 中配置 AI Provider 和 API Key。</p>
          </div>

          <div>
            <h3 class="font-semibold mb-3 flex items-center">
              <span class="bg-primary-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-sm mr-3">3</span>
              打开浏览器访问
            </h3>
            <CodeBlock class="ml-9" code="# Dashboard（Docker 部署）: http://localhost:3001\n# Server API: http://localhost:3000">
              <span class="text-gray-500"># Dashboard（Docker 部署）: http://localhost:3001</span><br/>
              <span class="text-gray-500"># Server API: http://localhost:3000</span>
            </CodeBlock>
            <p class="ml-9 mt-2 text-sm text-gray-500">首次启动时会自动创建管理员账号，密码显示在服务器日志中。</p>
          </div>
        </div>

        <div class="mt-8 border-t pt-6">
          <h3 class="font-semibold mb-3">其他安装方式</h3>
          <ul class="space-y-3 text-sm text-gray-600">
            <li class="flex items-start">
              <span class="text-primary-600 mr-2 mt-0.5 flex-shrink-0">&#8227;</span>
              <span><strong>从源码构建 Docker 镜像</strong> — 如果你不想使用预构建镜像，可以在克隆仓库后执行 <code class="bg-gray-100 px-1.5 py-0.5 rounded text-xs text-gray-800">docker compose -f docker-compose.yml -f docker-compose.build.yml up -d --build</code> 从本地源码构建并启动。</span>
            </li>
            <li class="flex items-start">
              <span class="text-primary-600 mr-2 mt-0.5 flex-shrink-0">&#8227;</span>
              <span><strong>源码开发环境</strong> — 面向开发者和贡献者，需要 Node.js 22+ 和 pnpm。详见 <a href="/docs/getting-started" class="text-primary-600 hover:underline">开发环境快速开始</a>。</span>
            </li>
          </ul>
          <p class="mt-4 text-sm text-gray-500">更多详细说明请查看 <a href="/docs" class="text-primary-600 hover:underline">官方文档</a>。</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
