---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="文档" description="ServerPilot 使用文档">
  <!-- BreadcrumbList 结构化数据 -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "首页", "item": "https://serverpilot.ai/" },
      { "@type": "ListItem", "position": 2, "name": "文档" }
    ]
  })} />

  <section class="container mx-auto px-6 py-20">
    <div class="max-w-5xl mx-auto">
      <!-- 面包屑导航 -->
      <nav class="text-sm text-gray-500 mb-8">
        <a href="/" class="hover:text-primary-600">首页</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">文档</span>
      </nav>

      <h1 class="text-4xl font-bold mb-6">文档中心</h1>
      <p class="text-gray-600 mb-12">快速上手 ServerPilot，掌握 AI 驱动的 DevOps 自动化</p>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- 快速开始 -->
        <div class="border rounded-lg p-6 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h2 class="text-xl font-semibold mb-3">快速开始</h2>
          <p class="text-gray-600 text-sm mb-4">5 分钟内完成安装并开始使用</p>
          <ul class="space-y-2 text-sm text-gray-600">
            <li><a href="/docs/getting-started#requirements" class="text-primary-600 hover:text-primary-700 hover:underline">• 系统要求</a></li>
            <li><a href="/docs/getting-started#installation" class="text-primary-600 hover:text-primary-700 hover:underline">• 安装指南</a></li>
            <li><a href="/docs/getting-started#first-setup" class="text-primary-600 hover:text-primary-700 hover:underline">• 首次配置</a></li>
          </ul>
        </div>

        <!-- 核心概念 -->
        <div class="border rounded-lg p-6 bg-gray-50/80 opacity-75">
          <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <h2 class="text-xl font-semibold mb-3 flex items-center gap-2">
            核心概念
            <span class="text-xs bg-gray-100 text-gray-500 px-2 py-0.5 rounded-full font-normal">即将推出</span>
          </h2>
          <p class="text-gray-600 text-sm mb-4">理解 ServerPilot 的核心架构</p>
          <ul class="space-y-2 text-sm text-gray-400">
            <li><span class="cursor-default">• Agent 架构</span></li>
            <li><span class="cursor-default">• AI 对话引擎</span></li>
            <li><span class="cursor-default">• 安全机制</span></li>
          </ul>
        </div>

        <!-- 使用指南 -->
        <div class="border rounded-lg p-6 bg-gray-50/80 opacity-75">
          <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h2 class="text-xl font-semibold mb-3 flex items-center gap-2">
            使用指南
            <span class="text-xs bg-gray-100 text-gray-500 px-2 py-0.5 rounded-full font-normal">即将推出</span>
          </h2>
          <p class="text-gray-600 text-sm mb-4">掌握常见运维任务的最佳实践</p>
          <ul class="space-y-2 text-sm text-gray-400">
            <li><span class="cursor-default">• 服务器管理</span></li>
            <li><span class="cursor-default">• 任务自动化</span></li>
            <li><span class="cursor-default">• 监控告警</span></li>
          </ul>
        </div>

        <!-- API 参考 -->
        <div class="border rounded-lg p-6 bg-gray-50/80 opacity-75">
          <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <h2 class="text-xl font-semibold mb-3 flex items-center gap-2">
            API 参考
            <span class="text-xs bg-gray-100 text-gray-500 px-2 py-0.5 rounded-full font-normal">即将推出</span>
          </h2>
          <p class="text-gray-600 text-sm mb-4">集成 ServerPilot 到你的应用</p>
          <ul class="space-y-2 text-sm text-gray-400">
            <li><span class="cursor-default">• REST API</span></li>
            <li><span class="cursor-default">• WebSocket 协议</span></li>
            <li><span class="cursor-default">• SDK 文档</span></li>
          </ul>
        </div>

        <!-- 部署运维 -->
        <div class="border rounded-lg p-6 bg-gray-50/80 opacity-75">
          <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
            </svg>
          </div>
          <h2 class="text-xl font-semibold mb-3 flex items-center gap-2">
            部署运维
            <span class="text-xs bg-gray-100 text-gray-500 px-2 py-0.5 rounded-full font-normal">即将推出</span>
          </h2>
          <p class="text-gray-600 text-sm mb-4">生产环境部署与维护</p>
          <ul class="space-y-2 text-sm text-gray-400">
            <li><span class="cursor-default">• Docker 部署</span></li>
            <li><span class="cursor-default">• 高可用架构</span></li>
            <li><span class="cursor-default">• 备份恢复</span></li>
          </ul>
        </div>

        <!-- 故障排查 -->
        <div class="border rounded-lg p-6 bg-gray-50/80 opacity-75">
          <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h2 class="text-xl font-semibold mb-3 flex items-center gap-2">
            故障排查
            <span class="text-xs bg-gray-100 text-gray-500 px-2 py-0.5 rounded-full font-normal">即将推出</span>
          </h2>
          <p class="text-gray-600 text-sm mb-4">常见问题解决方案</p>
          <ul class="space-y-2 text-sm text-gray-400">
            <li><span class="cursor-default">• 常见错误</span></li>
            <li><span class="cursor-default">• 调试技巧</span></li>
            <li><span class="cursor-default">• 性能优化</span></li>
          </ul>
        </div>
      </div>

      <!-- 快速链接 -->
      <div class="mt-16 bg-gray-50 rounded-lg p-8">
        <h2 class="text-2xl font-bold mb-6">快速链接</h2>
        <div class="grid md:grid-cols-3 gap-6">
          <div>
            <h3 class="font-semibold mb-3">入门教程</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="/docs/getting-started#installation" class="text-primary-600 hover:text-primary-700 hover:underline">→ 安装 ServerPilot</a></li>
              <li><a href="/docs/getting-started#first-setup" class="text-primary-600 hover:text-primary-700 hover:underline">→ 添加第一台服务器</a></li>
              <li><span class="text-gray-400 cursor-default">→ 创建第一个任务 <span class="text-xs bg-gray-200 text-gray-500 px-1.5 py-0.5 rounded-full ml-1">即将推出</span></span></li>
            </ul>
          </div>
          <div>
            <h3 class="font-semibold mb-3">进阶功能</h3>
            <ul class="space-y-2 text-sm text-gray-400">
              <li><span class="cursor-default">→ 自定义 AI 提示词 <span class="text-xs bg-gray-200 text-gray-500 px-1.5 py-0.5 rounded-full ml-1">即将推出</span></span></li>
              <li><span class="cursor-default">→ 配置 Webhook <span class="text-xs bg-gray-200 text-gray-500 px-1.5 py-0.5 rounded-full ml-1">即将推出</span></span></li>
              <li><span class="cursor-default">→ 团队协作 <span class="text-xs bg-gray-200 text-gray-500 px-1.5 py-0.5 rounded-full ml-1">即将推出</span></span></li>
            </ul>
          </div>
          <div>
            <h3 class="font-semibold mb-3">开发集成</h3>
            <ul class="space-y-2 text-sm text-gray-400">
              <li><span class="cursor-default">→ REST API 快速开始 <span class="text-xs bg-gray-200 text-gray-500 px-1.5 py-0.5 rounded-full ml-1">即将推出</span></span></li>
              <li><span class="cursor-default">→ WebSocket 事件 <span class="text-xs bg-gray-200 text-gray-500 px-1.5 py-0.5 rounded-full ml-1">即将推出</span></span></li>
              <li><span class="cursor-default">→ CLI 工具 <span class="text-xs bg-gray-200 text-gray-500 px-1.5 py-0.5 rounded-full ml-1">即将推出</span></span></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
