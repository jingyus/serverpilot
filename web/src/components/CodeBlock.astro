---
interface Props {
  /** Plain text to copy (without HTML). Required for clipboard. */
  code: string;
  /** Extra CSS classes on the outer wrapper */
  class?: string;
}

const { code, class: className = '' } = Astro.props;
---

<div class:list={["code-block relative group", className]}>
  <div class="bg-gray-900 text-gray-100 p-4 rounded-md font-mono text-sm overflow-x-auto pr-12">
    <slot />
  </div>
  <button
    type="button"
    class="copy-btn absolute top-2 right-2 bg-gray-700 hover:bg-gray-600 text-gray-300 hover:text-white rounded px-2 py-1 text-xs opacity-0 group-hover:opacity-100 transition-opacity"
    data-code={code}
  >
    复制
  </button>
</div>

<script>
  const timerMap = new WeakMap<HTMLButtonElement, number>();

  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.copy-btn') as HTMLButtonElement | null;
    if (!btn) return;

    const code = btn.dataset.code;
    if (!code) return;

    const prev = timerMap.get(btn);
    if (prev) clearTimeout(prev);

    navigator.clipboard.writeText(code).then(() => {
      btn.textContent = '已复制';
      btn.classList.add('bg-green-600', 'hover:bg-green-600', 'text-white');
      const timer = window.setTimeout(() => {
        btn.textContent = '复制';
        btn.classList.remove('bg-green-600', 'hover:bg-green-600', 'text-white');
        timerMap.delete(btn);
      }, 1500);
      timerMap.set(btn, timer);
    });
  });
</script>
