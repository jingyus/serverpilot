# ==============================================================================
# ServerPilot 环境变量配置模板
# ==============================================================================
# 注意: ServerPilot 采用零配置设计，开箱即用！
#       可直接运行 `docker compose up -d` 启动，无需配置此文件。
#       以下变量均为可选配置，仅在需要自定义时使用。
# ==============================================================================
# 如需自定义配置:
#   ./init.sh              # 引导式配置 + 启动 (推荐)
#   # 或手动配置:
#   cp .env.example .env   # 复制模板
#   # 编辑 .env 文件修改所需变量
#   docker compose up -d   # 启动服务
# ==============================================================================

# ------------------------------------------------------------------------------
# Docker Compose 配置
# ------------------------------------------------------------------------------

# Dashboard 外部访问端口 (浏览器访问 http://localhost:3001)
# 默认: 3001
DASHBOARD_PORT=3001

# ------------------------------------------------------------------------------
# 安全配置
# ------------------------------------------------------------------------------

# JWT 密钥 (至少 32 字符, 用于用户认证签名)
# 默认: default_jwt_secret_change_in_production
# 生产环境请务必修改!
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=change_me_to_a_random_string_at_least_32_chars

# ------------------------------------------------------------------------------
# 服务端配置
# ------------------------------------------------------------------------------

# 运行环境: development | production | test
# 默认: production
NODE_ENV=production

# 服务端监听端口
# 默认: 3000
SERVER_PORT=3000

# 监听地址
# 默认: 0.0.0.0
SERVER_HOST=0.0.0.0

# ------------------------------------------------------------------------------
# AI 配置 (可选 - AI 功能需要 API Key)
# ------------------------------------------------------------------------------

# AI Provider 选择: claude | openai | deepseek | ollama | custom-openai
# 默认: claude
# 说明:
#   claude       — Anthropic Claude (Tier 1, 推荐)
#   openai       — OpenAI 官方 API (Tier 2)
#   deepseek     — DeepSeek 官方 API (Tier 2)
#   ollama       — 本地 Ollama 实例 (Tier 3, 无需 API Key)
#   custom-openai — 任何 OpenAI 兼容 API (Tier 2, 适用于 OneAPI/LiteLLM/Azure 等)
AI_PROVIDER=claude

# AI 模型名称 (所有 Provider 通用)
# 不同 Provider 的推荐模型:
#   claude:        claude-sonnet-4-20250514
#   openai:        gpt-4o
#   deepseek:      deepseek-chat
#   ollama:        llama3
#   custom-openai: 取决于后端配置 (如 gpt-4o, deepseek-chat, claude-sonnet-4-20250514)
# 默认: claude-sonnet-4-20250514
AI_MODEL=claude-sonnet-4-20250514

# AI 请求超时 (毫秒)
# 适用于所有 Provider, custom-openai 默认 60000ms, 其他默认 30000ms
# 默认: 30000
AI_TIMEOUT_MS=30000

# AI 最大重试次数
# 默认: 3
AI_MAX_RETRIES=3

# --- Claude (AI_PROVIDER=claude) ---

# Anthropic Claude API Key
# 默认: 空 (AI 功能不可用，但系统仍可正常运行)
# 获取方式: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- OpenAI (AI_PROVIDER=openai) ---

# OpenAI API Key (仅 AI_PROVIDER=openai 时需要)
# 获取方式: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- DeepSeek (AI_PROVIDER=deepseek) ---

# DeepSeek API Key (仅 AI_PROVIDER=deepseek 时需要)
# 获取方式: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# --- Custom OpenAI 兼容 API (AI_PROVIDER=custom-openai) ---
# 适用于任何兼容 OpenAI /v1/chat/completions 接口的服务:
#   - OneAPI:  多模型聚合网关
#   - LiteLLM: 统一 LLM 代理
#   - Azure OpenAI: 微软 Azure 托管的 OpenAI
#   - vLLM / FastChat / LocalAI 等自建推理服务

# Custom OpenAI API Base URL (必填)
# 必须包含 /v1 路径前缀
# 示例:
#   OneAPI:    https://your-oneapi.example.com/v1
#   LiteLLM:  http://localhost:4000/v1
#   Azure:    https://your-resource.openai.azure.com/v1
#   vLLM:     http://localhost:8000/v1
CUSTOM_OPENAI_BASE_URL=

# Custom OpenAI API Key (必填)
# 由你的 API 网关或推理服务提供
CUSTOM_OPENAI_API_KEY=

# ------------------------------------------------------------------------------
# GitHub OAuth 配置 (可选 - 启用 GitHub 一键登录)
# ------------------------------------------------------------------------------

# GitHub OAuth App Client ID
# 创建方式: https://github.com/settings/applications/new
# 默认: 空 (GitHub 登录不可用)
GITHUB_OAUTH_CLIENT_ID=

# GitHub OAuth App Client Secret
# 默认: 空
GITHUB_OAUTH_CLIENT_SECRET=

# GitHub OAuth 回调地址
# 默认: http://localhost:3000/api/v1/auth/github/callback
# 生产环境需要修改为实际域名
GITHUB_OAUTH_REDIRECT_URI=

# ------------------------------------------------------------------------------
# WebSocket 配置
# ------------------------------------------------------------------------------

# WebSocket 心跳间隔 (毫秒)
# 默认: 30000
WS_HEARTBEAT_INTERVAL_MS=30000

# WebSocket 连接超时 (毫秒)
# 默认: 10000
WS_CONNECTION_TIMEOUT_MS=10000

# WebSocket 是否需要认证 (true | false)
# 默认: true
WS_REQUIRE_AUTH=true

# ------------------------------------------------------------------------------
# 知识库配置
# ------------------------------------------------------------------------------

# 知识库目录路径 (Docker 内部路径: /app/knowledge-base)
# 默认: ./knowledge-base
KNOWLEDGE_BASE_DIR=./knowledge-base

# GitHub API Token (用于文档自动抓取)
# 默认: 空 (不使用 GitHub API token，有速率限制)
# 获取方式: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# 文档自动抓取检查间隔 (小时)
# 默认: 24 (每天检查一次)
KB_CHECK_INTERVAL_HOURS=24

# 启动时是否立即运行文档抓取 (true | false)
# 默认: true
KB_RUN_ON_START=true

# 最大并发抓取数
# 默认: 3
KB_MAX_CONCURRENT=3

# ------------------------------------------------------------------------------
# 日志配置
# ------------------------------------------------------------------------------

# 日志级别: debug | info | warn | error
# 默认: info
LOG_LEVEL=info

# 日志文件路径 (Docker 环境留空，仅输出到控制台)
# 默认: 空
LOG_FILE=

# ------------------------------------------------------------------------------
# 数据库配置 (SQLite - 零配置)
# ------------------------------------------------------------------------------

# 数据库文件路径 (Docker 内部路径: /data/serverpilot.db)
# 默认: /data/serverpilot.db
# 注意: 数据持久化在 Docker volume 'server-data' 中
DATABASE_PATH=/data/serverpilot.db

# ------------------------------------------------------------------------------
# 客户端配置 (packages/agent)
# ------------------------------------------------------------------------------

# 服务端 WebSocket 地址
# 默认: ws://localhost:3000
INSTALL_SERVER_URL=ws://localhost:3000

# 命令执行超时 (毫秒)
# 默认: 120000
COMMAND_TIMEOUT_MS=120000

# 是否启用 dry-run 模式 (true | false)
# 默认: false
DRY_RUN=false

# ------------------------------------------------------------------------------
# 默认管理员账户 (仅首次启动时使用)
# ------------------------------------------------------------------------------

# 管理员邮箱
# 默认: admin@serverpilot.local
ADMIN_EMAIL=admin@serverpilot.local

# 管理员密码 (最少 8 字符)
# 默认: 空 (自动生成随机密码，显示在服务器日志中)
ADMIN_PASSWORD=
